# ---------------------------------------------------
# 1. Python & Environment
# ---------------------------------------------------
# Ignore virtual environments
venv/
env/
.env

# Ignore Python cache files
__pycache__/
*.py[cod]
*$py.class

# ---------------------------------------------------
# 2. Heavy Data & Machine Learning Models
# ---------------------------------------------------
# Ignore all downloaded and processed Hugging Face datasets
data/

# STRICTLY ignore model weights to prevent GitHub 100MB limit crashes
outputs/saved_models/
*.safetensors
*.bin
*.pt
*.pth
*.h5

# ---------------------------------------------------
# 3. IDE & System Files
# ---------------------------------------------------
# Ignore VS Code settings
.vscode/

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore Windows/Mac system files
Thumbs.db
.DS_Store